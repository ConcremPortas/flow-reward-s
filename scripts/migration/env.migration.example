# Template de variaveis para a migracao de dados V2.
# COPIE para .env.migration (que e ignorado pelo git) e preencha com as connection strings.
# NUNCA commite o arquivo preenchido. NUNCA compartilhe estas strings.
#
# Pegue as connection strings em: Supabase Dashboard -> Project Settings -> Database -> Connection string (URI).
# Use a string do POOLER (o host direto db.<ref>.supabase.co foi descontinuado).
# Lembre de URL-encodar caracteres especiais da senha (ex.: @ -> %40).

# Banco ANTIGO (origem — somente leitura)
SRC_DATABASE_URL="postgresql://postgres.SEU_REF_ANTIGO:SENHA_URLENCODED@aws-1-<regiao>.pooler.supabase.com:5432/postgres"

# Banco NOVO (destino — recebe os dados; migrations 0001-0010 ja aplicadas)
DST_DATABASE_URL="postgresql://postgres.SEU_REF_NOVO:SENHA_URLENCODED@aws-1-<regiao>.pooler.supabase.com:5432/postgres"
